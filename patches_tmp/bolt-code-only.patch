+
+inline constexpr const char* kSelfHealingHintPrefix = "bolt_self_healing_retry=true";
+
+struct DominantOperatorUsage {
+  std::string operatorName;
+    std::string operatorType;
+    std::string retryConfKey;
+    uint64_t usageBytes;
+};
+
+struct SelfHealingOverride {
+  std::string key;
+  std::string value;
+};
+
+inline std::string normalizeLower(std::string_view value) {
+  std::string normalized(value);
+  std::transform(
+      normalized.begin(),
+      normalized.end(),
+      normalized.begin(),
+      [](unsigned char c) { return static_cast<char>(std::tolower(c)); });
+  return normalized;
+}
+
+inline std::string trimCopy(std::string_view value) {
+  size_t begin = 0;
+  while (begin < value.size() &&
+         std::isspace(static_cast<unsigned char>(value[begin]))) {
+    ++begin;
+  }
+  size_t end = value.size();
+  while (end > begin &&
+         std::isspace(static_cast<unsigned char>(value[end - 1]))) {
+    --end;
+  }
+  return std::string(value.substr(begin, end - begin));
+}
+
+inline std::optional<uint64_t> parseByteValueToken(std::string_view token) {
+  const auto valueStart = token.find_first_not_of(' ');
+  if (valueStart == std::string_view::npos) {
+    return std::nullopt;
+  }
+
+  size_t numericEnd = valueStart;
+  while (numericEnd < token.size()) {
+    const auto c = static_cast<unsigned char>(token[numericEnd]);
+    if (!(std::isdigit(c) || c == '.')) {
+      break;
+    }
+    ++numericEnd;
+  }
+  if (numericEnd == valueStart) {
+    return std::nullopt;
+  }
+
+  size_t unitStart = numericEnd;
+  while (unitStart < token.size() &&
+         std::isspace(static_cast<unsigned char>(token[unitStart]))) {
+    ++unitStart;
+  }
+  if (unitStart == token.size()) {
+    return std::nullopt;
+  }
+
+  size_t unitEnd = unitStart;
+  while (unitEnd < token.size() &&
+         std::isalpha(static_cast<unsigned char>(token[unitEnd]))) {
+    ++unitEnd;
+  }
+  if (unitEnd == unitStart) {
+    return std::nullopt;
+  }
+
+  double numericValue = 0.0;
+  try {
+    numericValue =
+        std::stod(std::string(token.substr(valueStart, numericEnd - valueStart)));
+  } catch (const std::exception&) {
+    return std::nullopt;
+  }
+
+  auto unit = std::string(token.substr(unitStart, unitEnd - unitStart));
+  std::transform(unit.begin(), unit.end(), unit.begin(), [](unsigned char c) {
+    return static_cast<char>(std::toupper(c));
+  });
+
+  double multiplier = 0.0;
+  if (unit == "B") {
+    multiplier = 1.0;
+  } else if (unit == "KB") {
+    multiplier = 1024.0;
+  } else if (unit == "MB") {
+    multiplier = 1024.0 * 1024.0;
+  } else if (unit == "GB") {
+    multiplier = 1024.0 * 1024.0 * 1024.0;
+  } else if (unit == "TB") {
+    multiplier = 1024.0 * 1024.0 * 1024.0 * 1024.0;
+  } else {
+    return std::nullopt;
+  }
+
+  return static_cast<uint64_t>(std::llround(numericValue * multiplier));
+}
+
+inline std::optional<uint64_t> parseUsageBytes(std::string_view message) {
+  constexpr std::string_view usagePrefix = "current usage ";
+  constexpr std::string_view requestorPrefix = "requestor '";
+
+  const auto requestorPos = message.find(requestorPrefix);
+  if (requestorPos == std::string_view::npos) {
+    return std::nullopt;
+  }
+
+  const auto usagePos = message.find(usagePrefix);
+  if (usagePos == std::string_view::npos || usagePos >= requestorPos) {
+    return std::nullopt;
+  }
+
+  const auto valueStart = usagePos + usagePrefix.size();
+  return parseByteValueToken(message.substr(valueStart, requestorPos - valueStart));
+}
+
+inline bool isMemoryFailure(std::string_view message) {
+  auto normalized = normalizeLower(message);
+  return normalized.find("oom") != std::string::npos ||
+      normalized.find("outofmemory") != std::string::npos ||
+      normalized.find("out of memory") != std::string::npos ||
+      normalized.find("mem_cap_exceeded") != std::string::npos ||
+      normalized.find("memory pool cap") != std::string::npos ||
+      normalized.find("memory pressure") != std::string::npos ||
+      normalized.find("allocation failed") != std::string::npos ||
+      normalized.find("bad alloc") != std::string::npos ||
+      normalized.find("memory") != std::string::npos;
+}
+
+inline std::optional<DominantOperatorUsage> extractDominantOperatorUsage(
+    std::string_view message) {
+  std::istringstream lines{std::string(message)};
+  std::string line;
+  std::optional<DominantOperatorUsage> dominant;
+
+  while (std::getline(lines, line)) {
+    const auto opPos = line.find("op.");
+    const auto usagePos = line.find(" usage ");
+    if (opPos == std::string::npos || usagePos == std::string::npos || usagePos <= opPos) {
+      continue;
+    }
+
+    const auto operatorPath = trimCopy(
+        std::string_view(line).substr(opPos, usagePos - opPos));
+    const auto nameSep = operatorPath.find_last_of('.');
+    if (nameSep == std::string::npos || nameSep + 1 >= operatorPath.size()) {
+      continue;
+    }
+
+    const auto operatorName = operatorPath.substr(nameSep + 1);
+    const auto usageBytes =
+        parseByteValueToken(std::string_view(line).substr(usagePos + 7));
+    if (!usageBytes.has_value()) {
+      continue;
+    }
+
+    std::string operatorType;
+    std::string retryConfKey;
+    if (operatorName == "OrderBy") {
+      operatorType = "sort";
+      retryConfKey =
+          "spark.gluten.sql.columnar.backend.bolt.retry.sort.orderBySpillMemoryThreshold";
+    } else if (operatorName == "Aggregation") {
+      operatorType = "aggregate";
+      retryConfKey =
+          "spark.gluten.sql.columnar.backend.bolt.retry.aggregate.spillMemoryThreshold";
+    } else if (operatorName == "HashBuild") {
+      operatorType = "hashbuild";
+      retryConfKey =
+          "spark.gluten.sql.columnar.backend.bolt.retry.hashbuild.joinSpillMemoryThreshold";
+    } else {
+      continue;
+    }
+
+    if (!dominant.has_value() || usageBytes.value() > dominant->usageBytes) {
+      dominant = DominantOperatorUsage{
+          operatorName, operatorType, retryConfKey, usageBytes.value()};
+    }
+  }
+  return dominant;
+}
+
+inline std::string detectFailurePhase(std::string_view message) {
+  if (message.find("Operator::addInput failed") != std::string_view::npos) {
+    return "addInput";
+  }
+  if (message.find("Operator::noMoreInput failed") != std::string_view::npos) {
+    return "noMoreInput";
+  }
+  if (message.find("Operator::getOutput failed") != std::string_view::npos) {
+    return "getOutput";
+  }
+  return "unknown";
+}
+
+inline std::string detectCannotSpillReason(std::string_view message) {
+  if (message.find("SortBuffer::finishSpill") != std::string_view::npos) {
+    return "finishSpill";
+  }
+  if (message.find("createRowBasedOrderedReader") != std::string_view::npos) {
+    return "outputMerge";
+  }
+  if (message.find("getOutputWithSpill") != std::string_view::npos) {
+    return "getOutputWithSpill";
+  }
+  return "unknown";
+}
+
+inline std::string formatHint(
+    const std::string& operatorType,
+    const std::string& retryConfKey,
+    std::optional<uint64_t> dominantUsage,
+    const std::string& failurePhase,
+    const std::string& cannotSpillReason,
+    const std::vector<SelfHealingOverride>& overrides) {
+  std::vector<std::string> parts;
+  parts.emplace_back(kSelfHealingHintPrefix);
+  parts.emplace_back(fmt::format("operator_type={}", operatorType));
+  parts.emplace_back(fmt::format("dominant_operator={}", operatorType));
+  if (!retryConfKey.empty()) {
+    parts.emplace_back(fmt::format("retry_conf={}", retryConfKey));
+  }
+  if (dominantUsage.has_value()) {
+    parts.emplace_back(fmt::format("dominant_usage={}", dominantUsage.value()));
+  }
+  parts.emplace_back(fmt::format("failure_phase={}", failurePhase));
+  parts.emplace_back(fmt::format("cannot_spill_reason={}", cannotSpillReason));
+  parts.emplace_back(fmt::format("override_count={}", overrides.size()));
+  for (size_t i = 0; i < overrides.size(); ++i) {
+    parts.emplace_back(fmt::format("override_{}_key={}", i + 1, overrides[i].key));
+    parts.emplace_back(fmt::format("override_{}_value={}", i + 1, overrides[i].value));
+  }
+  std::string hint;
+  for (size_t i = 0; i < parts.size(); ++i) {
+    if (i > 0) {
+      hint += ";";
+    }
+    hint += parts[i];
+  }
+  return hint;
+}
+
+inline std::optional<uint64_t> computeRetryValueBytes(
+    const std::string& operatorType,
+    std::string_view message) {
+  if (operatorType != "sort") {
+    return std::nullopt;
+  }
+
+  if (auto dominant = extractDominantOperatorUsage(message);
+      dominant.has_value() && dominant->operatorType == "sort" &&
+      dominant->usageBytes >= 2) {
+    return dominant->usageBytes / 2;
+  }
+
+  if (message.find("requestor 'op.") == std::string_view::npos ||
+      message.find(".OrderBy'") == std::string_view::npos) {
+    return std::nullopt;
+  }
+  auto usageBytes = parseUsageBytes(message);
+  if (!usageBytes.has_value() || usageBytes.value() < 2) {
+    return std::nullopt;
+  }
+  return usageBytes.value() / 2;
+}
+
+} // namespace
+
+inline std::optional<std::string> buildSelfHealingHint(
+    const std::string& operatorType,
+    const std::string& retryConfKey,
+    const std::string& message) {
+  if (!isMemoryFailure(message)) {
+    return std::nullopt;
+  }
+
+  const auto dominantUsage = extractDominantOperatorUsage(message);
+  const auto failurePhase = detectFailurePhase(message);
+  const auto cannotSpillReason = detectCannotSpillReason(message);
+  const auto retryValue = computeRetryValueBytes(operatorType, message);
+  if (retryValue.has_value()) {
+    LOG(INFO) << "Bolt self-healing retry value computed"
+              << ", operator_type=" << operatorType
+              << ", retry_conf=" << retryConfKey
+              << ", retry_value=" << retryValue.value();
+    return formatHint(
+        operatorType,
+        retryConfKey,
+        dominantUsage.has_value() ? std::make_optional(dominantUsage->usageBytes) : std::nullopt,
+        failurePhase,
+        cannotSpillReason,
+        {{retryConfKey, std::to_string(retryValue.value())}});
+  }
+
+  return formatHint(
+      operatorType,
+      retryConfKey,
+      dominantUsage.has_value() ? std::make_optional(dominantUsage->usageBytes) : std::nullopt,
+      failurePhase,
+      cannotSpillReason,
+      {});
+}
+
+inline std::optional<std::string> buildSelfHealingHintFromFailure(
+    const std::string& message) {
+  if (!isMemoryFailure(message) ||
+      message.find(kSelfHealingHintPrefix) != std::string::npos) {
+    return std::nullopt;
+  }
+
+  const auto dominant = extractDominantOperatorUsage(message);
+  if (!dominant.has_value()) {
+    return std::nullopt;
+  }
+
+  std::vector<SelfHealingOverride> overrides;
+  if (const auto retryValue =
+          computeRetryValueBytes(dominant->operatorType, message);
+      retryValue.has_value()) {
+    overrides.push_back(
+        {dominant->retryConfKey, std::to_string(retryValue.value())});
+  }
+
+  LOG(INFO) << "Bolt self-healing hint generated"
+            << ", dominant_operator=" << dominant->operatorType
+            << ", dominant_usage=" << dominant->usageBytes
+            << ", failure_phase=" << detectFailurePhase(message)
+            << ", cannot_spill_reason=" << detectCannotSpillReason(message)
+            << ", override_count=" << overrides.size();
+
+  return formatHint(
+      dominant->operatorType,
+      dominant->retryConfKey,
+      dominant->usageBytes,
+      detectFailurePhase(message),
+      detectCannotSpillReason(message),
+      overrides);
+}
+
+} // namespace bytedance::bolt::exec
