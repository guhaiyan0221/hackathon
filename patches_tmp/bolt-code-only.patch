+#include "bolt/exec/SelfHealingUtils.h"
+
+#include <gtest/gtest.h>
+
+namespace bytedance::bolt::exec {
+namespace {
+
+TEST(SelfHealingUtilsTest, BuildsHintForAggregateOom) {
+  auto hint = buildSelfHealingHint(
+      "aggregate",
+      "spark.gluten.sql.columnar.backend.bolt.retry.aggregate.spillMemoryThreshold",
+      "OOM while allocating hash table");
+
+  ASSERT_TRUE(hint.has_value());
+  EXPECT_EQ(
+      hint.value(),
+      "bolt_self_healing_retry=true;operator_type=aggregate;retry_conf="
+      "spark.gluten.sql.columnar.backend.bolt.retry.aggregate.spillMemoryThreshold");
+}
+
+TEST(SelfHealingUtilsTest, DetectsMemoryFailuresCaseInsensitively) {
+  auto hint = buildSelfHealingHint(
+      "sort",
+      "spark.gluten.sql.columnar.backend.bolt.retry.sort.orderBySpillMemoryThreshold",
+      "Bad Alloc in SortBuffer");
+
+  ASSERT_TRUE(hint.has_value());
+  EXPECT_NE(hint.value().find("operator_type=sort"), std::string::npos);
+  EXPECT_NE(
+      hint.value().find(
+          "spark.gluten.sql.columnar.backend.bolt.retry.sort.orderBySpillMemoryThreshold"),
+      std::string::npos);
+}
+
+TEST(SelfHealingUtilsTest, AddsDynamicRetryValueForSortOom) {
+  auto hint = buildSelfHealingHint(
+      "sort",
+      "spark.gluten.sql.columnar.backend.bolt.retry.sort.orderBySpillMemoryThreshold",
+      "Exceeded memory pool cap of 60.00MB with max UNLIMITED when requesting 4.00MB, "
+      "memory manager cap is UNLIMITED, requestor 'op.2.0.0.OrderBy' with current usage "
+      "59.68MB, process RSS is 622.16MB");
+
+  ASSERT_TRUE(hint.has_value());
+  EXPECT_NE(hint.value().find("operator_type=sort"), std::string::npos);
+  EXPECT_NE(
+      hint.value().find(
+          "retry_value=31289508"),
+      std::string::npos);
+}
+
+TEST(SelfHealingUtilsTest, DetectsMemCapExceededFailures) {
+  auto hint = buildSelfHealingHint(
+      "aggregate",
+      "spark.gluten.sql.columnar.backend.bolt.retry.aggregate.spillMemoryThreshold",
+      "Error Code: MEM_CAP_EXCEEDED. Exceeded memory pool cap of 32.00MB");
+
+  ASSERT_TRUE(hint.has_value());
+  EXPECT_NE(hint.value().find("operator_type=aggregate"), std::string::npos);
+  EXPECT_EQ(hint.value().find("retry_value="), std::string::npos);
+}
+
+TEST(SelfHealingUtilsTest, IgnoresNonMemoryFailures) {
+  auto hint = buildSelfHealingHint(
+      "hashbuild",
+      "spark.gluten.sql.columnar.backend.bolt.retry.hashbuild.joinSpillMemoryThreshold",
+      "Unsupported join key type");
+
+  EXPECT_FALSE(hint.has_value());
+}
