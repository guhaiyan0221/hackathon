@@ -0,0 +1,9 @@
+INSERT OVERWRITE DIRECTORY '__QUERY_OUTPUT_DIR__'
+USING PARQUET
+SELECT k
+FROM bolt_self_healing_src
+WHERE k LIKE 'k_%'
+  AND CAST(SUBSTRING(k, 3) AS INT) < 600000
+ORDER BY concat(k, payload), k;
+
+SELECT 1 AS ok;
