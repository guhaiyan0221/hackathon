         first_text = fh.read()
     operator = classify_failure(first_text)
-    retry_conf = RETRY_CONF_BY_OPERATOR.get(operator)
+    retry_conf = parse_structured_retry_conf(first_text)
+    if retry_conf is None:
+        retry_conf = RETRY_CONF_BY_OPERATOR.get(operator)
     if retry_conf is None:
