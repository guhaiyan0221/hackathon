@@ -2,6 +2,7 @@
 
 import argparse
 import os
+import re
 import subprocess
 import sys
 import tempfile
@@ -55,6 +56,8 @@ RETRY_CONF_BY_OPERATOR = {
     },
 }
 
+STRUCTURED_HINT_PREFIX = "bolt_self_healing_retry=true;"
+
 
 def parse_args() -> argparse.Namespace:
     parser = argparse.ArgumentParser(
@@ -105,6 +108,39 @@ def classify_failure(log_text: str) -> Optional[str]:
     return None
 
 
+def parse_structured_retry_conf(log_text: str) -> Optional[Dict[str, str]]:
+    matches = re.findall(
+        rf"{re.escape(STRUCTURED_HINT_PREFIX)}[^\r\n]*", log_text, flags=re.MULTILINE
+    )
+    if not matches:
+        return None
+
+    fields: Dict[str, str] = {}
+    for token in matches[-1].split(";"):
+        if "=" not in token:
+            continue
+        key, value = token.split("=", 1)
+        fields[key] = value
+
+    try:
+        override_count = int(fields.get("override_count", "0"))
+    except ValueError:
+        return None
+
+    if override_count <= 0:
+        return None
+
+    retry_conf: Dict[str, str] = {}
+    for index in range(1, override_count + 1):
+        key = fields.get(f"override_{index}_key")
+        value = fields.get(f"override_{index}_value")
+        if not key or value is None:
+            return None
+        retry_conf[key] = value
+
+    return retry_conf or None
+
+
 SPARK_SUBMIT_OPTIONS_WITH_VALUES = {
     "--archives",
     "--class",
@@ -200,7 +236,9 @@ def main() -> int:
