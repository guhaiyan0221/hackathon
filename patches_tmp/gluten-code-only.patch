--- a/tools/bolt-self-healing/bolt_self_healing_demo.py
+++ /dev/null
@@ -1,64 +0,0 @@
-#!/usr/bin/env python3
-
-import argparse
-
-from pyspark.sql import SparkSession
-from pyspark.sql import functions as F
-
-
-def parse_args():
-    parser = argparse.ArgumentParser(
-        description="Generate a skewed aggregate workload for Bolt self-healing retry demo."
-    )
-    parser.add_argument("--rows", type=int, default=5_000_000)
-    parser.add_argument("--hot-ratio", type=float, default=0.95)
-    parser.add_argument("--payload-bytes", type=int, default=4096)
-    parser.add_argument("--shuffle-partitions", type=int, default=4)
-    parser.add_argument("--input-partitions", type=int, default=4)
-    parser.add_argument("--show-plan", action="store_true")
-    return parser.parse_args()
-
-
-def main():
-    args = parse_args()
-    spark = (
-        SparkSession.builder.appName("bolt-self-healing-demo-aggregate").getOrCreate()
-    )
-    spark.conf.set("spark.sql.shuffle.partitions", str(args.shuffle_partitions))
-
-    hot_cutoff = int(args.rows * args.hot_ratio)
-    base = spark.range(0, args.rows, 1, args.input_partitions)
-
-    df = (
-        base.select(
-            F.when(F.col("id") < F.lit(hot_cutoff), F.lit("hot"))
-            .otherwise(F.concat(F.lit("k_"), F.col("id").cast("string")))
-            .alias("k"),
-            F.repeat(F.lit("x"), args.payload_bytes).alias("payload"),
-        )
-        .repartition(args.input_partitions, "k")
-    )
-
-    agg = (
-        df.groupBy("k")
-        .agg(
-            F.count(F.lit(1)).alias("cnt"),
-            F.sum(F.length("payload")).alias("payload_bytes"),
-        )
-        .orderBy(F.desc("cnt"))
-    )
-
-    if args.show_plan:
-        agg.explain(mode="formatted")
-
-    rows = agg.collect()
-    print(f"result_size={len(rows)}")
-    print("top10=")
-    for row in rows[:10]:
-        print(row)
-
-    spark.stop()
-
-
-if __name__ == "__main__":
-    main()
